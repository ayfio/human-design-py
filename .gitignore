# .gitignore

# Python
__pycache__/
*.py[cod]# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/

# Компилированные расширения (ОСТАВИТЬ, Railway скомпилирует сам)
*.so
*.pyd

# =============================================================================
# Сборка и дистрибуция
# =============================================================================
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg


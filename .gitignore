# =============================================================================
venv/
ENV/
env/
.venv/
venv.bak/

# =============================================================================
# IDE и редакторы
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
*.sublime-project
*.sublime-workspace

# =============================================================================
# Environment variables (НИКОГДА не коммитить!)
# =============================================================================
.env
.env.local
.env.*.local
*.env
!.env.example  # ← Разрешаем пример для документации

# =============================================================================
# Railway / Render / Деплой
# =============================================================================
# Игнорируем локальные конфиги, но разрешаем шаблоны
.railway/
!.railway.example/
.render/
!.render.example/

# Локальные логи деплоя
railway.log
render.log

# =============================================================================
# Ephemeral / Временные данные
# =============================================================================
*.log
*.sqlite3
*.db
*.db-shm
*.db-wal
tmp/
temp/
*.tmp
*.temp


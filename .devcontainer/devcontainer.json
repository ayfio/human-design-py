{
  "name": "human-design-py",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "ms-vscode.vscode-json"
      ]
    }
  },
  "forwardPorts": [7860, 8000],
  "portsAttributes": {
    "7860": { "label": "Gradio UI", "onAutoForward": "openBrowser" },
    "8000": { "label": "FastAPI Docs", "onAutoForward": "notify" }
  }
}

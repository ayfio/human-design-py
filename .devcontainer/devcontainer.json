{
  "name": "human-design-py",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/apt-get-packages:1": {
      "packages": "build-essential,libssl-dev,libffi-dev,wget,unzip"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "ms-vscode.vscode-json",
        "littlefoxteam.vscode-python-test-adapter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && echo '✅ Dependencies installed. Run: python app_gradio.py'",
  "forwardPorts": [7860, 8000],
  "portsAttributes": {
    "7860": {
      "label": "Gradio UI",
      "onAutoForward": "openBrowser"
    },
    "8000": {
      "label": "FastAPI Docs",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "vscode"
}
